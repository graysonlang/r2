{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "debug",
      "postDebugTask": "Kill debug server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/main.mjs"]
    },
    {
      "name": "Debug in Chrome (https)",
      "type": "chrome",
      "request": "launch",
      "url": "https://localhost:8443",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "debug:https",
      "postDebugTask": "Kill debug server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/main.mjs"]
    },
    {
      "name": "Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src"
    }
  ]
}
